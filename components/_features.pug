// ==================== FEATURES ====================
section.section.features#features
  .container
    .section-header.reveal.reveal-1
      span.section-label 特色設施
      h2.section-title
        | 為創作而生的
        span.text-gold 空間配備
      span.gold-line
      p.section-subtitle 彈性、多元、高規格——滿足各種創作與活動需求

    .features__grid
      .feature-card.reveal.reveal-1
        span.feature-card__icon 👥
        h3.feature-card__title 容納約30人
        p.feature-card__desc 寬敞的長方型空間，靈活布置可容納多種規模的聚會與活動
      .feature-card.reveal.reveal-2
        span.feature-card__icon 🎭
        h3.feature-card__title 戲劇排練空間
        p.feature-card__desc 淨空設計，適合肢體訓練、表演排練、走位演練等戲劇需求
      .feature-card.reveal.reveal-3
        span.feature-card__icon 📖
        h3.feature-card__title 講座・工作坊
        p.feature-card__desc 安靜的地下環境，適合專注型學習、分享會、討論工作坊
      .feature-card.reveal.reveal-4
        span.feature-card__icon 🎬
        h3.feature-card__title 讀劇・小型展演
        p.feature-card__desc 獨特的場域氛圍，為小型演出、讀劇、沉浸式展演提供絕佳舞台
      .feature-card.reveal.reveal-5
        span.feature-card__icon 🪞
        h3.feature-card__title 落地大鏡面
        p.feature-card__desc 設有大面落地鏡，供舞蹈練習、肢體訓練及各式身體工作使用
      .feature-card.reveal.reveal-6
        span.feature-card__icon 🪵
        h3.feature-card__title 超耐磨木質石塑地板
        p.feature-card__desc 鋪設超耐磨木質石塑地板，兼顧美觀、耐用與環境舒適度
