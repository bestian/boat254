// ==================== CONTACT ====================
section.section.contact#contact
  .container
    .section-header.reveal.reveal-1
      span.section-label 聯絡我們
      h2.section-title
        | 歡迎登船，一起連結都市裡的孤島
      span.gold-line
      p.section-subtitle 社區行動提案、場地租借洽談、餐點預定－任何想要和我們連結的事，歡迎與我們聯繫：）

    .contact__inner
      .contact__info.reveal.reveal-1
        //- p.contact__cta-text
          | 無論是 1F 的社區合作、潛水艇計畫的場地租借，或非營利提案——歡迎來信、來電，或透過 Facebook 與我們聯繫。

        .contact__methods
          a.contact__method(href="mailto:urbanboat254@gmail.com")
            span.contact__method-icon ✉️
            div
              .contact__method-label 電子郵件
              .contact__method-value urbanboat254@gmail.com
          a.contact__method(href="tel:02-2881-5246")
            span.contact__method-icon 📞
            div
              .contact__method-label 電話
              .contact__method-value 02-2881-5246
          a.contact__method(href="https://www.facebook.com/p/%E5%B0%8F%E8%88%B9254%E8%99%9F-61581184477317/" target="_blank" rel="noopener noreferrer", title="Facebook")
            span.contact__method-icon 💬
            div
              .contact__method-label Facebook
              .contact__method-value 小船254號

      .contact__form-wrap.reveal.reveal-2
        h3.contact__form-title 傳送訊息給我們
        form(action="mailto:urbanboat254@gmail.com" method="get" enctype="text/plain" novalidate)
          .form-group
            label.form-label(for="name") 您的姓名
            input.form-input#name(type="text" name="name" placeholder="請輸入您的姓名" required)
          .form-group
            label.form-label(for="email") 電子郵件
            input.form-input#email(type="email" name="email" placeholder="your@email.com" required)
          .form-group
            label.form-label(for="subject") 主旨
            input.form-input#subject(type="text" name="subject" placeholder="場地租借 / 合作洽詢 / 其他")
          .form-group
            label.form-label(for="message") 訊息內容
            textarea.form-textarea#message(name="body" placeholder="請描述您的需求、活動日期或任何想法……" required)
          button.form-submit(type="submit") 🚀 送出訊息
