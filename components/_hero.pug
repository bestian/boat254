// ==================== HERO ====================
section.hero#hero(aria-label="首頁橫幅")
  .hero__bg(aria-hidden="true")
  .hero__overlay(aria-hidden="true")

  // Bubbles decoration
  .bubbles(aria-hidden="true")
    each _ in [1,2,3,4,5,6]
      span.bubble

  .hero__content
    span.hero__badge 台北士林 · 後港里 · 福港街254號

    h1.hero__title
      | 小船
      span.hero__title-accent 254

    .hero__divider(aria-hidden="true")
      span.hero__divider-line
      span.hero__divider-icon 🌊
      span.hero__divider-line.hero__divider-line--right

    p.hero__tagline
      | 1F・社區共創的友善餐飲空間
      br
      | B1・潛水艇計畫，可租借的排練與課程場地

    .hero__meta
      span.hero__meta-item
        span.hero__meta-icon 📍
        a(href="https://maps.app.goo.gl/iBiDVsqUGTTwTzph7" target="_blank" rel="noopener noreferrer", title="Google Maps")
          | 台北市士林區福港街254號
      span.hero__meta-item
        span.hero__meta-icon 🚇
        a(href="https://maps.app.goo.gl/i1RYX1ywbD3QEyJA7", target="_blank" rel="noopener noreferrer", title="步行路線圖")
          | 捷運劍潭站3號出口，步行約13分鐘

    .hero__cta
      a.btn.btn--primary(href="#boat254") 認識小船254
      a.btn.btn--outline(href="#submarine") 潛水艇計畫

  .hero__scroll-indicator(aria-hidden="true")
    span.hero__scroll-text Scroll
    span.hero__scroll-arrow
