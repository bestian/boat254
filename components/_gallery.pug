// ==================== 小船254 GALLERY ====================
section.section.gallery#gallery
  .container
    .section-header.reveal.reveal-1
      span.section-label 小船254 · 場地紀錄
      h2.section-title
        | 1F空間
        span.text-gold 即景
      span.gold-line

  .gallery__grid
    .gallery__item.reveal.reveal-1
      img(src="./img_202605/小船照片 (2)_對長者友善的空間.jpg" alt="對長者友善的空間" loading="lazy")
      .gallery__item__overlay
      .gallery__item__caption 對長者友善的空間
    .gallery__item.reveal.reveal-2
      img(src="./img_202605/小船照片 (3)_素雅的共創擺設.jpg" alt="素雅的共創擺設" loading="lazy")
      .gallery__item__overlay
      .gallery__item__caption 素雅的共創擺設
    .gallery__item.reveal.reveal-3
      img(src="./img_202605/小船照片 (4)_1F活動實況.jpg" alt="1F活動實況" loading="lazy")
      .gallery__item__overlay
      .gallery__item__caption 1F活動實況
    .gallery__item.reveal.reveal-4
      img(src="./img_202605/小船照片 (5)_共創共融的幸福空間.jpg" alt="共創共融的幸福空間" loading="lazy")
      .gallery__item__overlay
      .gallery__item__caption 共創共融的幸福空間
