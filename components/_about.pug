// ==================== ABOUT ====================
section.section.about#about
  .container
    .about__grid
      .about__image-wrap.reveal.reveal-1
        .about__frame(aria-hidden="true")
        img(src="IMG_5792_resized.jpg" alt="潛水艇計畫空間內部一景" loading="lazy")

      .about__text.reveal.reveal-2
        span.section-label 關於我們
        h2.section-title
          | 深潛於創作的
          br
          span.text-gold 地下空間
        span.gold-line.gold-line--left

        p.about__description
          | 小船254號坐落於台北士林後港里，一樓為咖啡／簡餐空間，地下一樓為「潛水艇計畫空間」——一個約15坪的長方型多功能場地，鋪設超耐磨木質石塑地板，設有大面落地鏡，為創作者、團隊及活動單位提供高度彈性的使用選擇。

        .about__tags
          span.about__tag 🎭 戲劇排練
          span.about__tag 📚 講座工作坊
          span.about__tag 🎨 藝術展演
          span.about__tag ☕ 咖啡簡餐
          span.about__tag 🪞 落地大鏡
          span.about__tag 🌳 士林社區

        .about__stats
          .about__stat
            .about__stat-value
              | 15
              span(style="font-size:1.2rem") 坪
            .about__stat-label 場地面積
          .about__stat
            .about__stat-value
              | 30
              span(style="font-size:1.2rem") 人
            .about__stat-label 最大容納
          .about__stat
            .about__stat-value B1
            .about__stat-label 地下一樓
