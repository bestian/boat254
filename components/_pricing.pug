// ==================== PRICING ====================
section.section.pricing#pricing
  .container
    .section-header.reveal.reveal-1
      span.section-label 租借費用
      h2.section-title
        | 透明
        span.text-gold 定價方案
      span.gold-line
      p.section-subtitle 彈性方案，讓每個創作計畫都能找到最適合的起點

    .pricing__grid
      //- Weekday
      .pricing-card.reveal.reveal-1
        .pricing-card__glow
        span.pricing-card__icon 🌙
        h3.pricing-card__title 平日方案
        p.pricing-card__period 週一至週五
        .pricing-card__price
          span.pricing-card__currency NT$
          span.pricing-card__amount 350
          span.pricing-card__unit / 小時
        .pricing-card__divider
        ul.pricing-card__perks
          li 全場獨立使用
          li 落地鏡面、木質地板
          li 彈性時段安排
          li 最小租借單位 1 小時

      //- Weekend – Featured
      .pricing-card.pricing-card--featured.reveal.reveal-2
        .pricing-card__glow
        span.pricing-card__icon ☀️
        h3.pricing-card__title 假日方案
        p.pricing-card__period 週六、週日
        .pricing-card__price
          span.pricing-card__currency NT$
          span.pricing-card__amount 400
          span.pricing-card__unit / 小時
        .pricing-card__divider
        ul.pricing-card__perks
          li 全場獨立使用
          li 落地鏡面、木質地板
          li 假日人潮活躍社區
          li 適合公開展演活動
        p.pricing-card__note 非營利組織假日：NT$300 / 小時

      //- 4hr Package
      .pricing-card.reveal.reveal-3
        .pricing-card__glow
        span.pricing-card__icon ⏱️
        h3.pricing-card__title 4小時方案
        p.pricing-card__period 彈性日期皆適用
        .pricing-card__price
          span.pricing-card__currency NT$
          span.pricing-card__amount 1,200
          span.pricing-card__unit / 4小時
        .pricing-card__divider
        ul.pricing-card__perks
          li 連續4小時包段
          li 全場獨立使用
          li 適合完整排練行程
          li 可分攤團隊費用
        p.pricing-card__note 每小時均攤 NT$300，超值划算

    //- Nonprofit banner
    .pricing__nonprofit.reveal.reveal-4
      .pricing__nonprofit-icon 🤝
      div
        h3.pricing__nonprofit-title 非營利組織優惠方案
        p.pricing__nonprofit-text
          | 非營利組織可洽談合作專案，享有
          strong(style="color: var(--color-gold-light);") 七五折優惠
          | ——假日每小時 NT$300。
          br
          | 我們相信創作與社會影響力應獲得更多支持，歡迎主動聯繫討論長期合作！
